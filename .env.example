# Fin-Guardian AI — Environment Configuration
# Copy this file to .env and fill in your values

# ── FastAPI Settings ─────────────────────────────────────────────────────
ENVIRONMENT=development
API_TITLE=Fin-Guardian AI
API_VERSION=1.0.0
DEBUG=true

# ── Redis Configuration ──────────────────────────────────────────────────
# Feature store for pre-computed user statistics
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Neo4j Configuration ──────────────────────────────────────────────────
# Graph database for money laundering network detection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fingurdain123
NEO4J_DATABASE=neo4j

# ── Kafka Configuration ──────────────────────────────────────────────────
# Message queue for HOLD event processing
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_HOLD_TOPIC=transactions.hold
KAFKA_INVESTIGATION_TOPIC=investigations.completed

# ── OpenAI / LLM Configuration ──────────────────────────────────────────
# For the AI detective agent (LangGraph)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4-turbo

# ── Fraud Detection Thresholds ──────────────────────────────────────────
# Risk score scale: 0.0 (safe) to 1.0 (fraud)
FRAUD_SCORE_THRESHOLD_HOLD=0.50    # Trigger investigation
FRAUD_SCORE_THRESHOLD_DENY=0.85    # Automatic block

# ── Performance Settings ────────────────────────────────────────────────
MAX_PROCESSING_TIME_MS=30.0        # 30ms hard constraint for Layer 1
FEATURE_CACHE_TTL_SECONDS=3600     # Cache user features for 1 hour

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
